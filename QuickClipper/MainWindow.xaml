<Window x:Class="QuickClipper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickClipper"
        Height="820"
        Width="1280"
        MinHeight="760"
        MinWidth="1120"
        Background="#F8FAFC"
        Foreground="#0F172A"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0" />
        <SolidColorBrush x:Key="TextBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#14B8A6" />
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#0F172A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="QuickClipper" FontSize="28" FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText" Text="Win+Shift+R to select an area." Style="{StaticResource MutedText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RecordButton" Content="Record" Width="104" Margin="0,0,8,0" Click="RecordButton_Click" />
                <Button x:Name="StopButton" Content="Stop" Width="104" Margin="0,0,14,0" IsEnabled="False" Click="StopButton_Click" />
                <Button Content="Open Folder" Width="116" Margin="0,0,8,0" Click="OpenSaveFolder_Click" />
                <Button x:Name="CopyButton" Content="Copy File" Width="104" Margin="0,0,8,0" IsEnabled="False" Click="CopyButton_Click" />
                <Button x:Name="ExportButton" Content="Export" Width="104" Style="{StaticResource PrimaryButton}" IsEnabled="False" Click="ExportButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="460" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="#0B1220" CornerRadius="12" ClipToBounds="True">
                    <Grid x:Name="PreviewHost" SizeChanged="PreviewHost_SizeChanged">
                        <Grid x:Name="EmptyPreviewPanel"
                              Background="#0B1220">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No clip loaded"
                                           Foreground="#E2E8F0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Use Win+Shift+R or Record to capture a region."
                                           Foreground="#94A3B8"
                                           FontSize="13"
                                           Margin="0,6,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <Image x:Name="PreviewFrame" Stretch="Uniform" />
                        <MediaElement x:Name="PreviewAudio"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Manual"
                                      Visibility="Collapsed" />
                        <Canvas x:Name="CropOverlayCanvas"
                                Background="Transparent"
                                MouseLeftButtonDown="CropOverlayCanvas_MouseLeftButtonDown"
                                MouseMove="CropOverlayCanvas_MouseMove"
                                MouseLeftButtonUp="CropOverlayCanvas_MouseLeftButtonUp">
                            <Rectangle x:Name="CropRect"
                                       Stroke="#41D6C3"
                                       StrokeThickness="2"
                                       Fill="#2241D6C3" />
                            <Rectangle x:Name="CropHandleTopLeft" Width="10" Height="10" Fill="White" Stroke="#111" />
                            <Rectangle x:Name="CropHandleTopRight" Width="10" Height="10" Fill="White" Stroke="#111" />
                            <Rectangle x:Name="CropHandleBottomLeft" Width="10" Height="10" Fill="White" Stroke="#111" />
                            <Rectangle x:Name="CropHandleBottomRight" Width="10" Height="10" Fill="White" Stroke="#111" />
                        </Canvas>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Margin="0,12,0,0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="12">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="PlayPauseButton" Content="Play" Width="78" Margin="0,0,8,0" Click="PlayPauseButton_Click" />
                            <Button x:Name="CutButton" Content="Start Cut" Width="96" Margin="0,0,8,0" Click="CutButton_Click" />
                            <Button x:Name="RemoveCutButton" Content="Remove Cut" Width="104" Click="RemoveCutButton_Click" />
                        </StackPanel>
                        <TextBlock x:Name="PreviewTimeText"
                                   Grid.Column="1"
                                   Width="136"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right"
                                   Text="00:00 / 00:00" />
                    </Grid>
                    <Canvas x:Name="TimelineCanvas"
                            Height="36"
                            Background="#F1F5F9"
                            MouseLeftButtonDown="TimelineCanvas_MouseLeftButtonDown"
                            MouseMove="TimelineCanvas_MouseMove"
                            MouseLeftButtonUp="TimelineCanvas_MouseLeftButtonUp">
                        <Rectangle x:Name="TrimBand" Height="36" Fill="#99D9D2" RadiusX="4" RadiusY="4" />
                        <Rectangle x:Name="StartHandle" Width="6" Height="36" Fill="#DC2626" RadiusX="2" RadiusY="2" />
                        <Rectangle x:Name="EndHandle" Width="6" Height="36" Fill="#2563EB" RadiusX="2" RadiusY="2" />
                        <Rectangle x:Name="PlayheadMarker" Width="3" Height="36" Fill="#0F172A" RadiusX="1.5" RadiusY="1.5" />
                    </Canvas>
                    <Grid Margin="0,6,0,0">
                        <TextBlock x:Name="TrimStartText" Text="Start 00:00.000" />
                        <TextBlock x:Name="TrimEndText" Text="End 00:00.000" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" Margin="18,0,0,0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <ScrollViewer Padding="16,16,10,16" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,18,0">
                    <ProgressBar x:Name="ExportProgressBar"
                                 Height="8"
                                 Margin="0,0,0,16"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed" />

                    <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,0,0,14" />
                    <TextBlock Text="Save folder" Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,4,0,10" LastChildFill="True">
                        <Button Content="..." Width="34" DockPanel.Dock="Right" Click="BrowseSaveFolder_Click" />
                        <TextBox x:Name="SaveFolderText" Margin="0,0,6,0" />
                    </DockPanel>

                    <TextBlock Text="FFmpeg path" Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,4,0,10" LastChildFill="True">
                        <Button Content="..." Width="34" DockPanel.Dock="Right" Click="BrowseFfmpeg_Click" />
                        <TextBox x:Name="FfmpegPathText" Margin="0,0,6,0" />
                    </DockPanel>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Max MB" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="MaxSizeText" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="FPS" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="FrameRateText" />
                        </StackPanel>
                    </Grid>
                    <CheckBox x:Name="QualityCapCheckBox"
                              Content="Quality length cap"
                              Margin="0,0,0,8"
                              Checked="QualitySetting_Changed"
                              Unchecked="QualitySetting_Changed" />
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Quality kbps at 1080p" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="QualityKbpsText"
                                 TextChanged="QualityText_TextChanged" />
                    </StackPanel>
                    <TextBlock x:Name="QualityBudgetText"
                               Foreground="#555"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <Button Content="Apply Max Quality Trim"
                            Height="30"
                            Margin="0,0,0,12"
                            Click="ApplyQualityTrim_Click" />
                    <CheckBox x:Name="IncludeAudioCheckBox"
                              Content="Record audio"
                              Margin="0,0,0,8"
                              Checked="AudioSetting_Changed"
                              Unchecked="AudioSetting_Changed" />
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Content="Start with Windows"
                              Margin="0,0,0,8"
                              Checked="StartupSetting_Changed"
                              Unchecked="StartupSetting_Changed" />
                    <TextBlock Text="GitHub repo URL" Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,4,0,10" LastChildFill="True">
                        <Button Content="Check" Width="58" DockPanel.Dock="Right" Click="CheckUpdatesButton_Click" />
                        <TextBox x:Name="UpdateRepositoryUrlText" Margin="0,0,6,0" />
                    </DockPanel>
                    <TextBlock Text="Captures desktop audio from the default Windows output."
                               Style="{StaticResource MutedText}"
                               Margin="0,0,0,10" />
                    <TextBlock x:Name="CurrentSettingsText"
                               Style="{StaticResource MutedText}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Encoder" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="EncoderComboBox"
                              Margin="0,4,0,16"
                              SelectionChanged="EncoderComboBox_SelectionChanged">
                        <ComboBoxItem Content="H.264 Medium" Tag="x264-medium" />
                        <ComboBoxItem Content="H.264 Slow" Tag="x264-slow" />
                        <ComboBoxItem Content="H.264 Veryslow" Tag="x264-veryslow" />
                        <ComboBoxItem Content="H.265 Medium" Tag="x265-medium" />
                        <ComboBoxItem Content="H.265 Slow" Tag="x265-slow" />
                        <ComboBoxItem Content="H.264 NVENC Fast" Tag="h264-nvenc-fast" />
                        <ComboBoxItem Content="H.264 NVENC Quality" Tag="h264-nvenc" />
                        <ComboBoxItem Content="H.264 NVENC Max" Tag="h264-nvenc-max" />
                        <ComboBoxItem Content="H.265 NVENC Fast" Tag="hevc-nvenc-fast" />
                        <ComboBoxItem Content="H.265 NVENC Quality" Tag="hevc-nvenc" />
                        <ComboBoxItem Content="H.265 NVENC Max" Tag="hevc-nvenc-max" />
                        <ComboBoxItem Content="All Test Exports" Tag="all-test" />
                    </ComboBox>
                    <Button Content="Benchmark Encoders" Height="30" Margin="0,0,0,16" Click="BenchmarkButton_Click" />

                    <Button Content="Save Settings" Height="32" Margin="0,0,0,18" Click="SaveSettings_Click" />

                    <TextBlock Text="Options" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,0,0,14" />
                    <TextBlock Text="Record hotkey" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="RecordHotKeyText"
                             Margin="0,4,0,10"
                             IsReadOnly="True"
                             PreviewKeyDown="RecordHotKeyText_PreviewKeyDown" />
                    <TextBlock Text="Reset hotkey" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="ResetHotKeyText"
                             Margin="0,4,0,18"
                             IsReadOnly="True"
                             PreviewKeyDown="ResetHotKeyText_PreviewKeyDown" />

                    <TextBlock Text="Crop" Style="{StaticResource SectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,8,8">
                            <TextBlock Text="X" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="CropXText" TextChanged="CropText_TextChanged" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Y" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="CropYText" TextChanged="CropText_TextChanged" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Width" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="CropWidthText" TextChanged="CropText_TextChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Height" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="CropHeightText" TextChanged="CropText_TextChanged" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Resize" Style="{StaticResource SectionTitle}" />
                    <Button Content="Auto 1280 x 720" Height="30" Margin="0,0,0,8" Click="Auto720Button_Click" />
                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Width" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="OutputWidthText" TextChanged="OutputSizeText_TextChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Height" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="OutputHeightText" TextChanged="OutputSizeText_TextChanged" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="ClipInfoText"
                   Margin="0,12,0,0"
                   Style="{StaticResource MutedText}"
                   Text="No clip loaded." />
    </Grid>
</Window>
