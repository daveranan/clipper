<Window x:Class="QuickClipper.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Canvas>
        <TextBlock x:Name="TimerText"
                   Text="00:00"
                   Canvas.Left="0"
                   Canvas.Top="0"
                   Padding="8,4"
                   Background="#CC111111"
                   Foreground="White"
                   FontWeight="SemiBold" />
        <Border x:Name="CaptureBorder"
                BorderBrush="#E5484D"
                BorderThickness="3" />
    </Canvas>
</Window>
