<Window x:Class="QuickClipper.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#88000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown">
    <Canvas x:Name="RootCanvas"
            Background="Transparent"
            MouseLeftButtonDown="RootCanvas_MouseLeftButtonDown"
            MouseMove="RootCanvas_MouseMove"
            MouseLeftButtonUp="RootCanvas_MouseLeftButtonUp"
            MouseRightButtonDown="RootCanvas_MouseRightButtonDown">
        <Rectangle x:Name="SelectionRect"
                   Stroke="#41D6C3"
                   StrokeThickness="2"
                   Fill="#2241D6C3"
                   Visibility="Collapsed" />
    </Canvas>
</Window>
