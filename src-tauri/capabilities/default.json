{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "region-selector"
  ],
  "permissions": [
    "core:default",
    "autostart:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all",
    "notification:default",
    "process:default",
    "updater:default"
  ]
}
